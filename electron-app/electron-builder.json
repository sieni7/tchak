{
  "appId": "art.tchak.free",
  "productName": "TCHAK FREE",
  "copyright": "Copyright © 2026 TCHAK!",
  "directories": {
    "output": "dist",
    "buildResources": "resources"
  },
  "asar": true,
  "compression": "maximum",
  "files": [
    "**/*",
    "!dist/*",
    "!**/node_modules/*",
    "!docs/*",
    "!tests/*",
    "!.git/*"
  ],
  "win": {
    "target": "nsis"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true
  },
  "mac": {
    "target": "dmg",
    "category": "public.app-category.graphics-design"
  },
  "linux": {
    "target": "AppImage",
    "category": "Graphics"
  }
}
