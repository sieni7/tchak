# Variables d'environnement Netlify – TCHAK Distribution System
# Copiez ce fichier en .env et remplissez les valeurs sur le dashboard Netlify

# ── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard : https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Optionnel : Service Role Key (pour les opérations admin) ──────────────────
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚡ Plan de génération (free ou pro) ⚡
TCHAK_PLAN=free
